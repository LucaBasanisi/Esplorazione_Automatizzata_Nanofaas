set export
set shell := ["bash", "-cu"]

# Colori per l'output (definiti tramite shell per evitare errori di escape in just)
YELLOW := `printf "\033[1;33m"`
BLUE := `printf "\033[0;34m"`
CYAN := `printf "\033[0;36m"`
NC   := `printf "\033[0m"`
GREEN := `printf "\033[0;32m"`
# Osservazione: quando scrivo @echo sto chiamando le funzioni della shell
# Potrebbe differire tra SO diversi (linux, mac...)

# Configurazione globale
# Queste variabili sono considerate GLOBALI, e quindi passate di default agli script successivi
# Workflow:
# 1. SELECTED_DISTRO viene passata a e2e-utils.sh
# 2. c'è un controllo if che vede se c'è scritto "alpine"
#   - se non c'è scritto nulla viene avviato ubuntu
# 3. Ora nella macchina virtuale multipass c'è una variabile BASE_IMAGE="alpine:3.20"
# 4. In tutti gli script, quando si crea il dockerfile: FROM $BASE_IMAGE


SELECTED_DISTRO := "alpine"
API_URL := "https://catfact.ninja/fact"
REGISTRY := "localhost:5000"
PROJECT_DIR := parent_directory(justfile_directory())
# se ho più snapshot sono in grado di individuare quello giusto
SNAPSHOT_NAME := "clean-setup"
VM_NAME := "nanofaas-k8s-dev"

# Perché non passare le variabili globali direttamente da e2e-utils.sh?
# Perché così sono in grado di fare un'iniziale controllo su che OS voglio usare
# e poi dopo posso mettere variabili globali più "specifiche"
# Se seleziono alpine devo usare apk (per installare java, python...)
# Se seleziono ubuntu devo usare apt
# Potrei usare una soluzione migliore? Probabile, ma questo è il mio 1° script bash, quindi fa niente



# Esegue i test principali
test-all: setup test-python test-java test-go test-stupid-import-python
    @echo -e "{{GREEN}}ALL EXTERNAL API AND SQL TESTS COMPLETED SUCCESSFULLY!{{NC}}"

# Digitare "just setup 3" per partire dallo step 3
setup step="1":
    @echo -e "{{BLUE}}======================================================{{NC}}"
    @echo -e "{{YELLOW}}>>> STEP: Setup VM & Workspace (Starting from step {{step}}){{NC}}"
    @echo -e "{{BLUE}}======================================================{{NC}}"
    ./tests/e2e-external-api-setup.sh {{step}}

